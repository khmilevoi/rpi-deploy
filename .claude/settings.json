{
  "permissions": {
    "allow": [
      "Bash(rtk git *)",
      "Bash(rtk cargo *)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/claude-rust-check.sh",
            "shell": "bash",
            "timeout": 180,
            "statusMessage": "cargo check (Rust edit)..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/claude-stop-check.sh",
            "shell": "bash",
            "timeout": 480,
            "statusMessage": "Running cargo fmt/clippy/test gate before finishing..."
          }
        ]
      }
    ]
  }
}
